# Example - DO NOT commit real secrets.
# Create secret: kubectl create secret generic automation-hub-secrets \
#   --from-literal=SESSION_SECRET=your-secret \
#   --from-literal=SMTP_USER=... --from-literal=SMTP_PASSWORD=... \
#   -n automation-hub

apiVersion: v1
kind: Secret
metadata:
  name: automation-hub-secrets
  labels:
    app: automation-hub
type: Opaque
stringData:
  SESSION_SECRET: "replace-with-a-random-32-byte-value"
  # SMTP_USER: "notifications@example.com"
  # SMTP_PASSWORD: "your-smtp-password"
  # ADMIN_EMAIL: "admin@example.com"
  # ADMIN_USER: "initial-admin@example.com"
  # ADMIN_PASS: "replace-with-a-strong-unique-password"
