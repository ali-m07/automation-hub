APP_NAME=Servexa
SSO_DEFAULT_MODULES=feedback_180
ENVIRONMENT=development
SESSION_SECRET=replace-with-a-long-random-value
FONT_DIR=fonts
MAX_FONT_UPLOAD_MB=20

POSTGRES_DB=automation
POSTGRES_USER=automation
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DSN=postgresql://automation:replace-with-a-strong-password@postgres:5432/automation

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Active Directory / LDAP
LDAP_ENABLED=false
LDAP_SERVER=ad.example.com
LDAP_PORT=636
LDAP_USE_SSL=true
LDAP_BASE_DN=DC=example,DC=com
LDAP_USER_PRINCIPAL={username}@example.com
LDAP_USER_FILTER=(sAMAccountName={username})
LDAP_BIND_USER=service-account@example.com
LDAP_BIND_PASSWORD=
LDAP_DIRECTORY_FILTER=(&(objectClass=user)(|(sAMAccountName={query})(displayName={query})(mail={query})))

# OIDC / Keycloak
OIDC_ENABLED=false
OIDC_PROVIDER_NAME=Keycloak
OIDC_DISCOVERY_URL=https://keycloak.example.com/realms/example/.well-known/openid-configuration
OIDC_CLIENT_ID=automation-hub
OIDC_CLIENT_SECRET=
OIDC_SCOPE=openid email profile
SSO_DEFAULT_MODULES=feedback
